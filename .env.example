# Copy to .env and fill in. .env is gitignored.

# --- OpenAI ---
OPENAI_API_KEY=sk-...

# Models (override here if you want to swap; defaults match config.py)
OPENAI_CHAT_MODEL=gpt-4o-mini
OPENAI_EMBED_MODEL=text-embedding-3-small

# --- Paths (relative to repo root; absolute also fine) ---
OLIST_CSV_DIR=./dataset
SQLITE_PATH=./data/olist.db
CHROMA_DIR=./data/chroma

# --- Runtime knobs ---
SQL_ROW_LIMIT=1000
SQL_TIMEOUT_SECONDS=10
RETRIEVER_TOP_K=5
